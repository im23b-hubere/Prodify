EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_REVENUECAT_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=Prodify Premium
# Copy to .env for local builds, or set in EAS (Project → Environment variables).
# EXPO_PUBLIC_* are inlined at build time.
#
# i18n: UI language follows the device (expo-localization), German + English bundled; fallback de.

# Required for release builds (production / TestFlight / Play). Use your deployed API origin (https).
# EXPO_PUBLIC_API_URL=https://api.example.com

# Optional: Sentry DSN for crash/error reporting (same project as @sentry/react-native wizard).
# EXPO_PUBLIC_SENTRY_DSN=

# Set automatically by eas.json build profiles; override when running `eas build --env` if needed.
# EXPO_PUBLIC_APP_ENV=production
