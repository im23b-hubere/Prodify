# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/prodify

# Security
SECRET_KEY=your-secret-key-min-32-chars
WEBHOOK_SECRET=your-webhook-secret-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# External Services
SENTRY_DSN=https://...
REVENUECAT_SECRET_KEY=your-rc-api-key
REVENUECAT_WEBHOOK_AUTH=your-rc-webhook-auth

# Push Notifications
FCM_SERVER_KEY=your-fcm-key
APNS_KEY_ID=your-apns-key
APNS_TEAM_ID=your-team-id
EXPO_ACCESS_TOKEN=your-expo-access-token

# Environment
ENVIRONMENT=production
LOG_JSON=true
CORS_ORIGINS=["https://prodify.app","https://www.prodify.app"]
RATE_LIMIT_AUTH_LOGIN=10/minute
RATE_LIMIT_AUTH_REGISTER=5/minute
