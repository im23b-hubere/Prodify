SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
# Short-lived JWT (minutes). Mobile renews via refresh tokens.
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Database ---
# Local/dev: SQLite is fine (single writer; avoid many concurrent writes).
DATABASE_URL=sqlite:///./prodify.db
#
# Production / higher concurrency: use PostgreSQL (or another server DB). Install deps: pip install -r requirements.txt
# Then run migrations against the same URL: alembic upgrade head
# Example (SQLAlchemy 2 + psycopg3):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/prodify
#
# Pool tuning applies only to non-SQLite URLs (defaults are safe for small/medium APIs):
# DATABASE_POOL_SIZE=5
# DATABASE_MAX_OVERFLOW=10
# DATABASE_POOL_PRE_PING=true
# DATABASE_POOL_RECYCLE_SECONDS=1800

# Browser origins allowed for CORS (comma-free JSON list). For production, set ENVIRONMENT=production and list only real https origins (no "*").
CORS_ORIGINS=["http://localhost:8081","http://127.0.0.1:8081","http://localhost:19006"]
# development | production — in production, CORS must be explicit (no wildcard).
ENVIRONMENT=development
# Brute-force protection on auth endpoints (slowapi format, e.g. 10/minute)
RATE_LIMIT_AUTH_LOGIN=10/minute
RATE_LIMIT_AUTH_REGISTER=5/minute

# --- Operations / observability ---
# LOG_JSON=true — stdout logs as JSON lines (containers / Loki / CloudWatch).
# LOG_JSON=false
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx — optional API error tracking.
# SENTRY_DSN=
# Protect POST /jobs/streak-reminders (GitHub Actions / cron). If unset, endpoint returns 503 with error=job_key_not_configured.
# INTERNAL_JOB_KEY=

# Optional: server-side Expo push (session complete + /notifications/ping-self)
# EXPO_ACCESS_TOKEN=
# Optional: FCM HTTP v1 for native Android tokens (channel=fcm) — service account JSON
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# or: FIREBASE_SERVICE_ACCOUNT_PATH=C:\secrets\firebase-adminsdk.json
