# Database
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/prodify

# Security
SECRET_KEY=your-secret-key-min-32-chars
WEBHOOK_SECRET=your-webhook-secret-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# External Services
SENTRY_DSN=https://...
# Optional; defaults are fine if unset. Match your Sentry project environment filter.
# SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.15
REVENUECAT_SECRET_KEY=your-rc-api-key
REVENUECAT_WEBHOOK_AUTH=your-rc-webhook-auth
LEGAL_PRIVACY_URL=https://prodify.app/privacy
LEGAL_TERMS_URL=https://prodify.app/terms
LEGAL_EFFECTIVE_DATE=2026-04-20
LEGAL_VERSION=2026.04
SUPPORT_EMAIL=support@prodify.app
FEATURE_FLAG_BILLING_SYNC_ENABLED=true
FEATURE_FLAG_PUSH_NOTIFICATIONS_ENABLED=true
FEATURE_FLAG_SMART_NUDGES_ENABLED=true

# Push Notifications
FCM_SERVER_KEY=your-fcm-key
APNS_KEY_ID=your-apns-key
APNS_TEAM_ID=your-team-id
EXPO_ACCESS_TOKEN=your-expo-access-token

# Environment
ENVIRONMENT=production
INTERNAL_JOB_KEY=your-internal-job-key-min-32-chars
LOG_JSON=true
CORS_ORIGINS=["https://prodify.app","https://www.prodify.app"]
RATE_LIMIT_AUTH_LOGIN=10/minute
RATE_LIMIT_AUTH_REGISTER=5/minute
