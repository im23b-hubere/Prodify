# Production template for backend deployment.
# Do not commit real secrets. Populate values in your hosting secret manager.

ENVIRONMENT=production
LOG_JSON=true

# Use a server database in production (PostgreSQL recommended).
# Example format: postgresql+psycopg://user:password@db-host:5432/prodify
DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:5432/<database>

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=<generate-strong-secret-key-min-50-chars>

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
INTERNAL_JOB_KEY=<generate-strong-internal-job-key-min-24-chars>

# Required for authenticated webhook endpoints
WEBHOOK_SECRET=<generate-webhook-secret-min-32-chars>

# Production CORS must be explicit HTTPS origins only.
CORS_ORIGINS=["https://prodify.app","https://www.prodify.app"]

# Sentry (required when ENVIRONMENT=production)
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project-id>
SENTRY_TRACES_SAMPLE_RATE=0.15

# Auth settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# RevenueCat / billing (if billing enabled)
REVENUECAT_SECRET_KEY=<revenuecat_secret_key>
REVENUECAT_WEBHOOK_AUTH=<revenuecat_webhook_auth>

# Legal / support metadata
LEGAL_PRIVACY_URL=https://prodify.app/privacy
LEGAL_TERMS_URL=https://prodify.app/terms
LEGAL_EFFECTIVE_DATE=2026-04-22
LEGAL_VERSION=2026.04
SUPPORT_EMAIL=support@prodify.app

# Feature flags
FEATURE_FLAG_BILLING_SYNC_ENABLED=true
FEATURE_FLAG_PUSH_NOTIFICATIONS_ENABLED=true
FEATURE_FLAG_SMART_NUDGES_ENABLED=true

# Optional push providers
FCM_SERVER_KEY=<fcm_server_key>
APNS_KEY_ID=<apns_key_id>
APNS_TEAM_ID=<apns_team_id>
EXPO_ACCESS_TOKEN=<expo_access_token>
